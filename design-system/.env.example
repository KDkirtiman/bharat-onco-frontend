# ─────────────────────────────────────────────────────────────────────
# Bharat Oncology Frontend — Environment Variables
# Copy this file to design-system/.env and fill in values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────────

# API base URL — points to bharat-onco-platform backend
VITE_API_URL=http://localhost:8085

# App environment
VITE_APP_ENV=development

# Sentry (added in P2 — Issue #87)
# VITE_SENTRY_DSN=
